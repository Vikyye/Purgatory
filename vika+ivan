# ---------- ИГРОК ----------
class Player:
    def __init__(self):
        self.width = int(screen.width // 11)
        self.height = int(screen.height // 4.5)
        self.x = screen.width // 2 - self.width // 2
        self.y = Y_GROUND - self.height
        self.speed = 5
        self.color = (180, 180, 180)
        self.jump_power = -15
        self.on_ground = True
        self.y_velocity = 0
        self.x_velocity = 0

    def move(self, keys):
        if keys[pg.K_LEFT] or keys[pg.K_a]:
            self.x_velocity -= self.speed
        if keys[pg.K_RIGHT] or keys[pg.K_d]:
            self.x_velocity += self.speed
        if (keys[pg.K_SPACE] or keys[pg.K_w]) and self.on_ground:
            self.y_velocity = self.jump_power
            self.on_ground = False
        self.x_velocity *= 0.82
        self.x += self.x_velocity
        self.y += self.y_velocity
        if not self.on_ground:
            self.y_velocity += GRAVITY
        self.check_ground()

    def check_ground(self):
        if self.y + self.height >= Y_GROUND:
            self.y = Y_GROUND - self.height
            self.y_velocity = 0
            self.on_ground = True
        else:
            self.on_ground = False

    def draw(self, surface, camera_x):
        pg.draw.rect(surface, self.color, (self.x - camera_x, self.y, self.width, self.height))

# ---------- ДЕРЕВО САКУРЫ ----------
class SakuraTree:
    def __init__(self, x, y, trunk_height=40, trunk_width=10, crown_radius=35):
        self.x = x
        self.y = y
        self.trunk_height = trunk_height
        self.trunk_width = trunk_width
        self.crown_radius = crown_radius
        self.branches = []
        for _ in range(8):
            angle = random.uniform(-60, 60)
            length = random.uniform(0.3, 0.8) * crown_radius
            bx = self.x + math.sin(math.radians(angle)) * self.trunk_width * 0.5
            by = self.y - self.trunk_height * random.uniform(0.3, 0.8)
            self.branches.append((angle, length, bx, by))

    def get_rect(self):
        left = self.x - self.crown_radius
        top = self.y - self.trunk_height - self.crown_radius - 10
        width = self.crown_radius * 2
        height = self.trunk_height + self.crown_radius + 10
        return pg.Rect(left, top, width, height)

    def draw(self, surface, camera_x):
        draw_x = self.x - camera_x
        if draw_x > screen.width + 50 or draw_x < -50:
            return
        # Ствол
        for i in range(self.trunk_height):
            y_pos = self.y - i
            w = int(self.trunk_width * (1 - (i / self.trunk_height) * 0.4))
            color_val = 60 + (i / self.trunk_height) * 30
            color = (int(color_val), int(color_val * 0.7), int(color_val * 0.4))
            pg.draw.rect(surface, color, (draw_x - w//2, y_pos, w, 1))
        # Ветки
        for angle, length, bx, by in self.branches:
            ex = bx + math.sin(math.radians(angle)) * length
            ey = by - math.cos(math.radians(angle)) * length * 0.5
            pg.draw.line(surface, TRUNK_LIGHT, (bx - camera_x, by), (ex - camera_x, ey), 2)
        # Крона
        cx, cy = draw_x, self.y - self.trunk_height - 10
        pg.draw.circle(surface, PINK, (cx, cy), self.crown_radius)
        offsets = [
            (-self.crown_radius*0.6, -self.crown_radius*0.3, 0.7),
            (self.crown_radius*0.6, -self.crown_radius*0.3, 0.7),
            (-self.crown_radius*0.4, -self.crown_radius*0.7, 0.6),
            (self.crown_radius*0.4, -self.crown_radius*0.7, 0.6),
            (-self.crown_radius*0.7, -self.crown_radius*0.5, 0.5),
            (self.crown_radius*0.7, -self.crown_radius*0.5, 0.5),
            (0, -self.crown_radius*0.9, 0.5),
        ]
        for ox, oy, scale in offsets:
            r = int(self.crown_radius * scale * 0.8)
            pg.draw.circle(surface, LIGHT_PINK, (int(cx + ox), int(cy + oy)), r)
        dark_offsets = [
            (-self.crown_radius*0.3, -self.crown_radius*0.1, 0.4),
            (self.crown_radius*0.3, -self.crown_radius*0.1, 0.4),
            (-self.crown_radius*0.1, -self.crown_radius*0.5, 0.5),
            (self.crown_radius*0.1, -self.crown_radius*0.5, 0.5),
        ]
        for ox, oy, scale in dark_offsets:
            r = int(self.crown_radius * scale * 0.9)
            pg.draw.circle(surface, DARK_PINK, (int(cx + ox), int(cy + oy)), r)
        # Цветочки
        for _ in range(30):
            angle = random.uniform(0, 2 * math.pi)
            dist = random.uniform(0.2, 1.0) * self.crown_radius
            fx = cx + math.cos(angle) * dist
            fy = cy + math.sin(angle) * dist * 0.8
            size = random.randint(2, 5)
            pg.draw.circle(surface, (255, 230, 240), (int(fx), int(fy)), size)

# ---------- ЧАСТИЦЫ ----------
class AshParticle:
    def __init__(self, world_width):
        self.x = random.randint(0, world_width)
        self.y = random.randint(-100, screen.height)
        self.size = random.randint(3, 8)
        self.speed_y = random.uniform(0.5, 1.5)
        self.speed_x = random.uniform(-0.3, 0.3)
        self.color = (random.randint(40, 80), random.randint(40, 70), random.randint(40, 70))

    def update(self):
        self.x += self.speed_x
        self.y += self.speed_y
        if self.y > screen.height + 20:
            self.y = -20
            self.x = random.randint(0, WORLD_WIDTH)
        if self.x < -20:
            self.x = WORLD_WIDTH + 20
        if self.x > WORLD_WIDTH + 20:
            self.x = -20

    def draw(self, surface, camera_x):
        draw_x = self.x - camera_x
        if -50 < draw_x < screen.width + 50:
            pg.draw.circle(surface, self.color, (int(draw_x), int(self.y)), self.size)

class FogParticle:
    def __init__(self, world_width):
        self.x = random.randint(0, world_width)
        self.y = random.randint(0, screen.height)
        self.radius = random.randint(60, 150)
        self.speed_x = random.uniform(-0.1, 0.1)
        self.speed_y = random.uniform(-0.05, 0.05)
        self.alpha = random.randint(40, 100)
        self.color = (30, 30, 35, self.alpha)

    def update(self):
        self.x += self.speed_x
        self.y += self.speed_y
        if self.x < -200:
            self.x = WORLD_WIDTH + 200
        if self.x > WORLD_WIDTH + 200:
            self.x = -200
        if self.y < -200:
            self.y = screen.height + 200
        if self.y > screen.height + 200:
            self.y = -200

    def draw(self, surface, camera_x):
        draw_x = self.x - camera_x
        if -200 < draw_x < screen.width + 200:
            fog = pg.Surface((self.radius * 2, self.radius * 2), pg.SRCALPHA)
            pg.draw.circle(fog, self.color, (self.radius, self.radius), self.radius)
            surface.blit(fog, (draw_x - self.radius, self.y - self.radius))

