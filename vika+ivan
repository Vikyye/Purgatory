def draw_game():
    global camera_x, show_e_button, button_rect, animation_active

    for ash in ash_particles:
        ash.update()
    for fog in fog_particles:
        fog.update()

    target_cam = player.x - screen.width // 2 + player.width // 2
    camera_x += (target_cam - camera_x) * 0.1
    camera_x = max(0, min(camera_x, WORLD_WIDTH - screen.width))

    # Фон
    for i in range(screen.height):
        t = i / screen.height
        r = int(10 + t * 10)
        g = int(10 + t * 15)
        b = int(30 + t * 40)
        pg.draw.line(screen.surface, (r, g, b), (0, i), (screen.width, i))

    for fog in fog_particles:
        fog.draw(screen.surface, camera_x)

    pg.draw.rect(screen.surface, ABYSS_COLOR, (0 - camera_x, Y_GROUND + GROUND_HEIGHT, WORLD_WIDTH, screen.height - (Y_GROUND + GROUND_HEIGHT)))
    pg.draw.rect(screen.surface, GROUND_COLOR, (0 - camera_x, Y_GROUND, WORLD_WIDTH, GROUND_HEIGHT))

    big_tree.draw(screen.surface, camera_x)

    for ash in ash_particles:
        ash.draw(screen.surface, camera_x)

    player.draw(screen.surface, camera_x)

    if show_e_button:
        tree_center_world_x = big_tree.x
        tree_top_world_y = big_tree.y - big_tree.trunk_height - big_tree.crown_radius - 10
        btn_x_world = tree_center_world_x - 30
        btn_y_world = tree_top_world_y - 20
        btn_x_screen = btn_x_world - camera_x
        btn_y_screen = btn_y_world
        button_rect = pg.Rect(btn_x_screen, btn_y_screen, 60, 40)

        mouse_x, mouse_y = pg.mouse.get_pos()
        hover = button_rect.collidepoint(mouse_x, mouse_y)
        draw_e_button(screen.surface, button_rect, hover, animation_active)

# ---------- ОСНОВНОЙ ЦИКЛ ----------
def main():
    global state, animation_active, animation_start, player, camera_x, show_e_button

    clock = pg.time.Clock()
    running = True
    state = 'MENU'
    fullscreen = True

    while running:
        for event in pg.event.get():
            if event.type == pg.QUIT:
                running = False

            if event.type == pg.KEYDOWN:
                if event.key == pg.K_ESCAPE:
                    if state == 'GAME':
                        state = 'MENU'
                    else:
                        running = False
                if event.key == pg.K_e and state == 'GAME' and show_e_button and not animation_active:
                    animation_active = True
                    animation_start = pg.time.get_ticks()
                if event.key == pg.K_F4:
                    fullscreen = not fullscreen
                    if fullscreen:
                        screen.update(screen.save_width, screen.save_height)
                    else:
                        new_w = int(screen.width // 1.75)
                        new_h = int(screen.height // 1.75)
                        screen.update(new_w, new_h)
                    if background_og:
                        bg_scaled = pg.transform.scale(background_og, (screen.width, screen.height))

            if event.type == pg.MOUSEBUTTONDOWN and event.button == 1:
                mx, my = event.pos
                if state == 'MENU':
                    for i, item in enumerate(menu_items):
                        y = start_y + i * (item_height + MENU_SPACING)
                        rect = pg.Rect(screen.width // 2 - 150, y, 300, item_height)
                        if rect.collidepoint(mx, my):
                            if item == "Авторы":
                                state = 'AUTHORS'
                            elif item == "Новая игра":
                                state = 'GAME'
                                player.x = screen.width // 2 - player.width // 2
                                player.y = Y_GROUND - player.height
                                player.y_velocity = 0
                                player.x_velocity = 0
                                player.on_ground = True
                                camera_x = 0
                            elif item == "Помощь":
                                webbrowser.open(link_url)
                            elif item == "Выход":
                                running = False
                elif state == 'AUTHORS':
                    back_rect = pg.Rect(screen.width // 2 - 60, screen.height - 60, 120, 40)
                    if back_rect.collidepoint(mx, my):
                        state = 'MENU'
                elif state == 'GAME':
                    if show_e_button and button_rect is not None:
                        if button_rect.collidepoint(mx, my) and not animation_active:
                            animation_active = True
                            animation_start = pg.time.get_ticks()

        # Логика игры
        if state == 'GAME':
            keys = pg.key.get_pressed()
            player.move(keys)
            if player.x < 0:
                player.x = 0
            if player.x + player.width > WORLD_WIDTH:
                player.x = WORLD_WIDTH - player.width

            player_rect = pg.Rect(player.x, player.y, player.width, player.height)
            tree_rect = big_tree.get_rect()
            show_e_button = player_rect.colliderect(tree_rect)

            if animation_active and pg.time.get_ticks() - animation_start > ANIMATION_DURATION:
                animation_active = False

        # Отрисовка
        if state == 'MENU':
            draw_menu()
        elif state == 'AUTHORS':
            draw_authors()
        elif state == 'GAME':
            draw_game()

        pg.display.flip()
        clock.tick(FPS)

    pg.quit()
    sys.exit()

if __name__ == "__main__":
    main()
